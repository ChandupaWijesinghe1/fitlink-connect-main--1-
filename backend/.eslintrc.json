{
  "env": {
    "node": true,
    "es2021": true,
    "jest": true,
    "commonjs": true
  },
  "extends": "airbnb-base",
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "script"
  },
  "rules": {
    "no-console": "warn",
    "func-names": "off",
    "no-underscore-dangle": "off",
    "consistent-return": "warn"
  },
  "overrides": [
    {
      "files": ["**/*.test.js", "**/__tests__/**/*.js"],
      "env": {
        "jest": true
      },
      "rules": {
        "no-undef": "off"
      }
    }
  ]
}